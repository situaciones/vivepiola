SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=condoadmin
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Correo: en desarrollo usa 'django.core.mail.backends.console.EmailBackend'
# En produccion usa 'django.core.mail.backends.smtp.EmailBackend' con un proveedor
# transaccional (SendGrid, Mailgun, SMTP propio del condominio/administradora).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=notificaciones@tu-administradora.cl

# Clave API de Anthropic para extraccion asistida de infracciones desde el
# reglamento de copropiedad (PDF). El administrador siempre debe revisar y
# confirmar manualmente antes de que una infraccion quede activa en el catalogo.
ANTHROPIC_API_KEY=

# WhatsApp (Twilio) — canal COMPLEMENTARIO de aviso (el legal es el correo).
# Dejar vacio deshabilita el canal sin afectar el flujo.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Almacenamiento persistente de archivos (DigitalOcean Spaces / S3).
# CRITICO en produccion: sin esto, evidencias/PDFs/reglamentos se pierden en
# cada deploy (disco efimero). Dejar el bucket vacio usa disco local (solo dev).
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
AWS_S3_REGION_NAME=nyc3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True

# Parametros legales (Ley 21.442)
NOVEDADES_PLAZO_RESPUESTA_DIAS=20
REINCIDENCIA_VENTANA_MESES=6
DESCARGO_PLAZO_DEFAULT_DIAS=5
