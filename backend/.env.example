SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=condoadmin
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Correo: en desarrollo usa 'django.core.mail.backends.console.EmailBackend'
# En produccion usa 'django.core.mail.backends.smtp.EmailBackend' con un proveedor
# transaccional (SendGrid, Mailgun, SMTP propio del condominio/administradora).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=notificaciones@tu-administradora.cl

# Clave API de Anthropic para extraccion asistida de infracciones desde el
# reglamento de copropiedad (PDF). El administrador siempre debe revisar y
# confirmar manualmente antes de que una infraccion quede activa en el catalogo.
ANTHROPIC_API_KEY=

# Parametros legales (Ley 21.442)
NOVEDADES_PLAZO_RESPUESTA_DIAS=20
REINCIDENCIA_VENTANA_MESES=6
DESCARGO_PLAZO_DEFAULT_DIAS=5
